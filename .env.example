# ── Free LLM Provider Keys ────────────────────────────────────────────────────
# Add at least one. All are free-tier with daily/per-minute limits.
# Fastest for Pi Zero 2W (lowest first-token latency):

GROQ_API_KEY=gsk_...          # https://console.groq.com/keys  — daily reset
GEMINI_API_KEY=AIza...        # https://aistudio.google.com/app/apikey
GITHUB_TOKEN=ghp_...          # any GitHub PAT — free with any account

# ── Optional providers ────────────────────────────────────────────────────────
# OPENROUTER_API_KEY=sk-or-...  # https://openrouter.ai/keys
# CEREBRAS_API_KEY=csk-...      # https://cloud.cerebras.ai
# MISTRAL_API_KEY=...           # https://console.mistral.ai
# NVIDIA_API_KEY=nvapi-...      # https://build.nvidia.com
# COHERE_API_KEY=...            # https://dashboard.cohere.com
# HF_API_KEY=hf_...             # https://huggingface.co/settings/tokens

# ── Multiply free quota with extra accounts ───────────────────────────────────
# Add numbered variants — the proxy auto-discovers them and rotates on 429.
# Each slot is a separate account (different email / GitHub account).
#
# GROQ_API_KEY_2=gsk_...        # second Groq account  → 2× daily limit
# GROQ_API_KEY_3=gsk_...        # third  Groq account  → 3× daily limit
# GEMINI_API_KEY_2=AIza...      # same pattern works for any provider
# GITHUB_TOKEN_2=ghp_...
